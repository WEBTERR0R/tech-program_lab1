{
  "name": "lab-project",
  "version": "1.0.0",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "lint-staged": {
    "frontend/src/**/*.{ts,tsx}": [
      "cd frontend && npm run lint",
      "cd frontend && npm run format"
    ],
    "backend/src/**/*.ts": [
      "cd backend && npm run lint",
      "cd backend && npm run format"
    ]
  }
}