{
  "name": "lab-project",
  "version": "1.0.0",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "lint-staged": "^15.0.0"
  },
  "lint-staged": {
    "frontend/src/**/*.{ts,tsx}": [
      "npm --prefix frontend run lint",
      "npm --prefix frontend run format"
    ],
    "backend/src/**/*.ts": [
      "npm --prefix backend run lint",
      "npm --prefix backend run format"
    ]
  }
}
